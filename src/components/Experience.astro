---
import { experience } from '../data/experience';
---

<section class="experience" id="experience">
  <div class="container">
    <span class="section-label">Experience</span>

    <div class="exp-list">
      {experience.map((entry) => (
        <article class="exp-row">
          <div class="exp-meta">
            <span class="exp-dates">{entry.dateRange}</span>
            <span class="exp-location">{entry.location}</span>
          </div>
          <div class="exp-body">
            <h3 class="exp-org">{entry.organization}</h3>
            <p class="exp-role">{entry.role}</p>
            <p class="exp-desc">{entry.description}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .exp-list {
    display: flex;
    flex-direction: column;
  }

  .exp-row {
    display: grid;
    gap: 0.5rem;
    padding: 1.75rem 0;
    border-top: 1px solid var(--color-border);
  }

  .exp-row:first-child {
    border-top: none;
    padding-top: 0;
  }

  @media (min-width: 640px) {
    .exp-row {
      grid-template-columns: 11rem 1fr;
      gap: 2rem;
    }
  }

  .exp-meta {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .exp-dates {
    font-size: var(--text-small);
    font-weight: 500;
    color: var(--color-text-primary);
    font-variant-numeric: oldstyle-nums;
  }

  .exp-location {
    font-size: var(--text-micro);
    color: var(--color-text-tertiary);
  }

  .exp-org {
    font-size: var(--text-subhead);
    font-weight: 500;
    margin-bottom: 0.15rem;
  }

  .exp-role {
    font-size: var(--text-small);
    font-weight: 500;
    color: var(--color-accent);
    margin-bottom: 0.6rem;
  }

  .exp-desc {
    font-size: var(--text-small);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
    max-width: 60ch;
  }
</style>
