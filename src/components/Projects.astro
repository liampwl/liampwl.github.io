---
import { projects } from '../data/projects';
---

<section class="projects" id="projects">
  <div class="container">
    <span class="section-label">Research &amp; Projects</span>

    <div class="projects-grid">
      {projects.map((project) => (
        <article class="project">
          <h3 class="project-title">
            {project.github || project.url ? (
              <a href={project.url ?? project.github} target="_blank" rel="noopener noreferrer">{project.title}</a>
            ) : (
              project.title
            )}
          </h3>
          <p class="project-meta">
            {project.date}{project.association ? ` · ${project.association}` : ''}
          </p>
          <p class="project-desc">{project.description}</p>
          <p class="project-tags">{project.tags.join(' · ')}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .projects-grid {
    display: grid;
    gap: 2.5rem 3rem;
  }

  @media (min-width: 700px) {
    .projects-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .project-title {
    font-size: var(--text-subhead);
    font-weight: 500;
    margin-bottom: 0.25rem;
  }

  .project-title a {
    text-decoration: none;
  }

  .project-title a:hover {
    text-decoration: underline;
    text-decoration-color: var(--color-accent);
  }

  .project-meta {
    font-size: var(--text-micro);
    color: var(--color-text-tertiary);
    margin-bottom: 0.75rem;
  }

  .project-desc {
    font-size: var(--text-small);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
    margin-bottom: 0.6rem;
  }

  .project-tags {
    font-size: var(--text-micro);
    font-style: italic;
    font-family: var(--font-display);
    color: var(--color-text-tertiary);
  }
</style>
