---
import { Image } from 'astro:assets';
import headshot from '../assets/headshot.jpg';
---

<section class="intro" id="intro">
  <div class="container intro-inner">
    <div class="intro-text">
      <p class="intro-kicker">MPH candidate · UNC Gillings School of Global Public Health</p>

      <h1 class="intro-headline">
        Working on the gap between global health policy and the people who deliver it.
      </h1>

      <p class="intro-bio">
        I'm a second-year MPH candidate focused on global health implementation and
        health systems. My work has centered on HIV/AIDS and WASH, with experience
        spanning USAID's Office of HIV/AIDS, FHI&nbsp;360, and the Water Institute at UNC.
      </p>

      <aside class="intro-now">
        <span class="intro-now-label">Currently</span>
        <p>
          Writing from Hanoi, where I'm spending the summer researching disruptions to
          HIV prevention service delivery at a clinic affiliated with Hanoi Medical University.
        </p>
      </aside>

      <p class="intro-links">
        <a href="mailto:william.powell@unc.edu">Email</a>
        <span aria-hidden="true">·</span>
        <a href="/resume.pdf">CV</a>
        <span aria-hidden="true">·</span>
        <a href="https://linkedin.com/in/williampwl" target="_blank" rel="noopener noreferrer">LinkedIn</a>
        <span aria-hidden="true">·</span>
        <a href="https://github.com/liampwl" target="_blank" rel="noopener noreferrer">GitHub</a>
      </p>
    </div>

    <div class="intro-photo">
      <Image
        src={headshot}
        alt="Liam Powell"
        width={640}
        height={640}
        format="webp"
        quality={85}
        loading="eager"
        fetchpriority="high"
      />
      <p class="intro-photo-caption">Chapel Hill, N.C. — and this summer, Hanoi.</p>
    </div>
  </div>
</section>

<style>
  .intro {
    padding-top: 4.5rem;
  }

  .intro-inner {
    display: grid;
    gap: 3rem;
    align-items: start;
  }

  @media (min-width: 768px) {
    .intro-inner {
      grid-template-columns: 1.6fr 1fr;
      gap: 4rem;
    }
  }

  .intro-kicker {
    font-size: var(--text-micro);
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-tertiary);
    margin-bottom: 1.5rem;
  }

  .intro-headline {
    font-size: var(--text-display);
    font-weight: 500;
    letter-spacing: -0.01em;
    margin-bottom: 1.5rem;
    text-wrap: balance;
  }

  .intro-bio {
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
    margin-bottom: 2rem;
    max-width: 56ch;
  }

  .intro-now {
    border-left: 2px solid var(--color-accent);
    padding-left: 1.25rem;
    margin-bottom: 2rem;
    max-width: 52ch;
  }

  .intro-now-label {
    display: block;
    font-size: var(--text-micro);
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 0.35rem;
  }

  .intro-now p {
    font-family: var(--font-display);
    font-style: italic;
    font-size: var(--text-subhead);
    line-height: var(--leading-snug);
    color: var(--color-text-primary);
  }

  .intro-links {
    font-size: var(--text-small);
    color: var(--color-text-tertiary);
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .intro-photo {
    max-width: 320px;
  }

  .intro-photo :global(img) {
    width: 100%;
    height: auto;
    border: 1px solid var(--color-rule);
    padding: 0.4rem;
    background: var(--color-bg-elevated);
  }

  .intro-photo-caption {
    font-family: var(--font-display);
    font-style: italic;
    font-size: var(--text-small);
    color: var(--color-text-tertiary);
    margin-top: 0.75rem;
  }

  @media (max-width: 767px) {
    .intro-photo {
      max-width: 240px;
    }
  }
</style>
